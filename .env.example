# -----------------------------------------------------------------------------
# PrivaForge env template. Copy to `.env.local` and fill in.
#
# NEVER commit real secrets. NEVER put secrets in NEXT_PUBLIC_* vars.
# -----------------------------------------------------------------------------

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon) — required for migrations and server routes
DATABASE_URL=postgres://user:password@localhost:5432/privaforge

# Auth (Clerk) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Payments (Stripe) — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Set to bypass env validation during static analysis. NEVER set in production.
# SKIP_ENV_VALIDATION=1
