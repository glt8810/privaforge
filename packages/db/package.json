{
  "name": "@privaforge/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle schema, migrations, and typed client for PrivaForge Postgres.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5",
    "drizzle-orm": "^0.35.3",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "drizzle-kit": "^0.26.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
