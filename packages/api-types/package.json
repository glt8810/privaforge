{
  "name": "@privaforge/api-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types for PrivaForge API boundaries (client <-> server).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.58.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
